{
  "name": "tigerex-users-desktop",
  "version": "1.0.0",
  "description": "TigerEx Users Desktop Application",
  "authors": ["TigerEx Team"],
  "license": "MIT",
  "repository": "",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "TigerEx Users",
    "identifier": "com.tigerex.users",
    "windows": {
      "wix": null,
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.tigerex.users",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "windows": {
        "nsis": {
          "installMode": "currentUser"
        }
      }
    },
    "security": {
      "CSP": null
    },
    "windows": {
      "fullscreen": false,
      "resizable": true,
      "title": "TigerEx Users",
      "width": 1200,
      "height": 800,
      "minWidth": 800,
      "minHeight": 600
    }
  }
}