# ==========================================
# TigerEx Environment Configuration
# @file .env.example
# @description Example environment variables for TigerEx trading platform
# @author TigerEx Development Team
# @version v12.0.0
# ==========================================

# ========================================
# APPLICATION CONFIGURATION
# ========================================
NODE_ENV=production
APP_NAME=TigerEx
APP_VERSION=v12.0.0
APP_DESCRIPTION=Professional Cryptocurrency Trading Platform for Traders, VIP, Affiliate & Institutions

# Server
PORT=3000
API_PORT=8000
HOST=0.0.0.0
API_HOST=0.0.0.0

# URLs
NEXT_PUBLIC_APP_URL=https://tigerex.com
NEXT_PUBLIC_API_URL=https://api.tigerex.com
NEXT_PUBLIC_WS_URL=wss://ws.tigerex.com

# CORS
CORS_ORIGIN=https://tigerex.com,https://www.tigerex.com
CORS_CREDENTIALS=true

# ========================================
# DATABASE CONFIGURATION
# ========================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/tigerex
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tigerex
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_MAX_CONNECTIONS=200

# MongoDB
MONGO_URI=mongodb://localhost:27017/tigerex
MONGO_USER=tigerex
MONGO_PASSWORD=change_me_in_production

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production
REDIS_DB=0

# ========================================
# MESSAGE BROKER
# ========================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=tigerex
RABBITMQ_PASSWORD=change_me_in_production
RABBITMQ_VHOST=/

# ========================================
# SECURITY
# ========================================
SECRET_KEY=change_me_use_strong_random_key_min_32_chars
JWT_SECRET=change_me_use_strong_random_key_min_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION=86400

# Encryption
ENCRYPTION_KEY=change_me_32_char_encryption_key
ENCRYPTION_ALGORITHM=aes-256-gcm

# Session
SESSION_SECRET=change_me_session_secret_min_32_chars
SESSION_EXPIRY=3600

# API Keys
API_KEY_HEADER=X-API-Key
API_RATE_LIMIT=100

# ========================================
# AUTHENTICATION
# ========================================
AUTH_JWT_SECRET=change_me_use_strong_random_key
AUTH_TOKEN_EXPIRY=3600
REFRESH_TOKEN_EXPIRY=604800
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGITS=true
PASSWORD_REQUIRE_SPECIAL=true

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# 2FA
TOTP_ISSUER=TigerEx
TOTP_WINDOW=1

# ========================================
# EMAIL & NOTIFICATIONS
# ========================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@tigerex.com
SMTP_PASSWORD=change_me
SMTP_FROM=TigerEx <noreply@tigerex.com>
SMTP_USE_TLS=true

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@tigerex.com

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Push Notifications
FCM_SERVER_KEY=
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=ap2

# ========================================
# TRADING CONFIGURATION
# ========================================
# Exchange APIs
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=true

OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

KRAKEN_API_KEY=
KRAKEN_API_SECRET=

MEXC_API_KEY=
MEXC_API_SECRET=

HUOBI_ACCESS_KEY=
HUOBI_SECRET_KEY=

GATE_API_KEY=
GATE_API_SECRET=

# Trading Limits
MAX_ORDER_SIZE=1000000
MIN_ORDER_SIZE=10
MAX_LEVERAGE=125
DEFAULT_LEVERAGE=10

# Trading Fees
MAKER_FEE=0.001
TAKER_FEE=0.001
VIP_MAKER_FEE=0.0005
VIP_TAKER_FEE=0.0005
INSTITUTION_MAKER_FEE=0.0002
INSTITUTION_TAKER_FEE=0.0002

# ========================================
# PAYMENT GATEWAYS
# ========================================
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

ADYEN_MERCHANT_ACCOUNT=
ADYEN_API_KEY=
ADYEN_CLIENT_KEY=

# Fiat
FIAT_PROVIDER=
FIAT_API_KEY=

# ========================================
# BLOCKCHAIN
# ========================================
WEB3_RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID
WEB3_WS_URL=wss://mainnet.infura.io/ws/v3/YOUR_PROJECT_ID

PRIVATE_KEY=change_me_64_char_hex_private_key

# Contract Addresses
TOKEN_CONTRACT_ADDRESS=
STAKING_CONTRACT_ADDRESS=

# ========================================
# KYC & COMPLIANCE
# ========================================
KYC_ENABLED=true
KYC_PROVIDER=
KYC_API_KEY=

# ID Verification
ID_VERIFICATION_REQUIRED=true
ID_MIN_AGE=18

# AML
AML_ENABLED=true
AML_SCREENING_ENABLED=true

# Limits
KYC_UNVERIFIED_WITHDRAWAL_LIMIT=100
KYC_VERIFIED_WITHDRAWAL_LIMIT=10000
KYC_COMPLETED_WITHDRAWAL_LIMIT=1000000

# ========================================
# FEATURES
# ========================================
FEATURE_P2P_ENABLED=true
FEATURE_FUTURES_ENABLED=true
FEATURE_OPTIONS_ENABLED=true
FEATURE_STAKING_ENABLED=true
FEATURE_LAUNCHPAD_ENABLED=true
FEATURE_COPY_TRADING_ENABLED=true
FEATURE_SOCIAL_TRADING_ENABLED=true

# Referral
REFERRAL_ENABLED=true
REFERRAL_COMMISSION_RATE=0.2
REFERRAL_TIER_2_COMMISSION_RATE=0.1

# VIP Program
VIP_TIER_1_VOLUME=10000
VIP_TIER_2_VOLUME=100000
VIP_TIER_3_VOLUME=1000000
VIP_TIER_4_VOLUME=10000000
VIP_TIER_5_VOLUME=100000000

# ========================================
# MONITORING & LOGGING
# ========================================
LOG_LEVEL=info
LOG_FORMAT=json

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# Datadog
DATADOG_API_KEY=
DATADOG_SERVICE_NAME=tigerex

# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# StatsD
STATSD_HOST=localhost
STATSD_PORT=8125

# ========================================
# CLOUDS & STORAGE
# ========================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=tigerex-assets

GCP_PROJECT_ID=
GCP_KEY_FILE=

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=tigerex
MINIO_SECURE=false

# ========================================
# CACHE & PERFORMANCE
# ========================================
CACHE_TTL=300
CACHE_PREFIX=tigerex

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ========================================
# EXTERNAL SERVICES
# ========================================
# Market Data
ALPHA_VANTAGE_API_KEY=
IEX_CLOUD_API_KEY=
COINGECKO_API_KEY=

# News
NEWS_API_KEY=

# Social
TWITTER_API_KEY=
TWITTER_API_SECRET=
DISCORD_WEBHOOK_URL=

# ========================================
# ADMIN
# ========================================
ADMIN_EMAIL=admin@tigerex.com
ADMIN_PASSWORD=change_me_strong_password

MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=TigerEx is under scheduled maintenance

# ========================================
# AFFILIATE PROGRAM
# ========================================
AFFILIATE_ENABLED=true
AFFILIATE_COMMISSION_RATE=0.3
AFFILIATE_MULTI_TIER_ENABLED=true
AFFILIATE_TIER_2_RATE=0.15
AFFILIATE_TIER_3_RATE=0.05

# ========================================
# INSTITUTIONAL
# ========================================
INSTITUTIONAL_ENABLED=true
INSTITUTIONAL_API_ENABLED=true
INSTITUTIONAL_ACCOUNT_MANAGER=true

# ========================================
# DEVELOPMENT (DO NOT USE IN PRODUCTION)
# ========================================
DEBUG=false
TEST_MODE=false
MOCK_PAYMENTS=false# TigerEx Wallet API
# create_wallet() - 24-word seed
