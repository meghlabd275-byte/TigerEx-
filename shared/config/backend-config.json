{
  "name": "tigerex-backend",
  "version": "1.0.0",
  "description": "TigerEx Unified Backend Services",
  "baseUrl": "https://api.tigerex.com",
  "wsUrl": "wss://stream.tigerex.com",
  "ports": {
    "api": 8000,
    "websocket": 8001,
    "admin": 8002,
    "worker": 8003
  },
  "database": {
    "primary": {
      "type": "postgresql",
      "host": "localhost",
      "port": 5432,
      "database": "tigerex",
      "username": "tigerex_user",
      "poolSize": 20
    },
    "cache": {
      "type": "redis",
      "host": "localhost",
      "port": 6379,
      "db": 0
    },
    "mongodb": {
      "type": "mongodb",
      "host": "localhost",
      "port": 27017,
      "database": "tigerex_logs"
    }
  },
  "security": {
    "jwt": {
      "secret": "${JWT_SECRET}",
      "accessTokenExpiry": "30m",
      "refreshTokenExpiry": "7d",
      "algorithm": "HS256"
    },
    "rateLimit": {
      "windowMs": 60000,
      "maxRequests": 100
    },
    "cors": {
      "allowedOrigins": ["https://tigerex.com", "https://www.tigerex.com"],
      "allowedMethods": ["GET", "POST", "PUT", "DELETE", "PATCH"],
      "allowedHeaders": ["Content-Type", "Authorization", "X-Platform"]
    }
  },
  "features": {
    "trading": {
      "spotTrading": true,
      "marginTrading": true,
      "futuresTrading": true,
      "p2pTrading": true,
      "copyTrading": true,
      "apiTrading": true
    },
    "wallet": {
      "deposit": true,
      "withdrawal": true,
      "convert": true,
      "convertAll": true
    },
    "earn": {
      "staking": true,
      "savings": true,
      "launchpool": true,
      "meganDrop": true,
      "ido": true
    },
    "kyc": {
      "enabled": true,
      "requireForTrading": true,
      "requireForWithdrawal": true
    }
  },
  "userRoles": {
    "trader": {
      "id": "trader",
      "permissions": ["trade", "wallet", "p2p", "earn"]
    },
    "vip": {
      "id": "vip",
      "permissions": ["trade", "wallet", "p2p", "earn", "api"]
    },
    "affiliate": {
      "id": "affiliate",
      "permissions": ["trade", "wallet", "p2p", "earn", "referral"]
    },
    "institution": {
      "id": "institution",
      "permissions": ["trade", "wallet", "p2p", "earn", "api", "institutional"]
    },
    "p2pMerchant": {
      "id": "p2p_merchant",
      "permissions": ["trade", "wallet", "p2p", "earn"]
    },
    "liquidityProvider": {
      "id": "liquidity_provider",
      "permissions": ["trade", "wallet", "earn", "liquidity"]
    },
    "whiteLabel": {
      "id": "white_label",
      "permissions": ["trade", "wallet", "p2p", "earn", "api", "whiteLabel"]
    }
  },
  "adminRoles": {
    "superAdmin": {
      "id": "super_admin",
      "permissions": ["*"]
    },
    "admin": {
      "id": "admin",
      "permissions": ["users", "trading", "wallet", "p2p", "earn", "settings"]
    },
    "moderator": {
      "id": "moderator",
      "permissions": ["users.view", "users.moderate"]
    },
    "listingManager": {
      "id": "listing_manager",
      "permissions": ["assets", "listing"]
    },
    "supportTeam": {
      "id": "support_team",
      "permissions": ["tickets", "users.view"]
    },
    "complianceManager": {
      "id": "compliance_manager",
      "permissions": ["kyc", "compliance"]
    }
  },
  "assets": [
    { "symbol": "BTC", "name": "Bitcoin", "type": "crypto", "network": "Bitcoin" },
    { "symbol": "ETH", "name": "Ethereum", "type": "crypto", "network": "Ethereum" },
    { "symbol": "USDT", "name": "Tether", "type": "stablecoin", "network": "Ethereum" },
    { "symbol": "BNB", "name": "Binance Coin", "type": "crypto", "network": "BNBChain" }
  ],
  "fiatCurrencies": ["USD", "EUR", "GBP", "CNY", "JPY", "KRW"],
  "paymentMethods": ["bank_transfer", "credit_card", "debit_card", "paypal", "skrill"],
  "websocket": {
    "channels": ["trades", "orderbook", "ticker", "klines", "user_orders", "user_trades"]
  }
}