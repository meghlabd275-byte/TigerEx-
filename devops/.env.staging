# ============================================
# TigerEx Staging Environment
# AWS/GCP/Azure staging configuration
# ============================================

# Application
NODE_ENV=staging
ENVIRONMENT=staging
DEBUG=false
LOG_LEVEL=info

# Backend
BACKEND_PORT=8005
FRONTEND_PORT=3000

# Database (Replace with staging DB URL)
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:5432/${DB_NAME}

# Redis (Replace with staging Redis URL)
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:6379/0

# JWT (CHANGE THIS IN PRODUCTION)
JWT_SECRET=CHANGE_ME_USE_STRONG_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API URLs
API_URL=https://staging-api.tigerex.com
WS_URL=wss://staging-api.tigerex.com

# CORS
CORS_ORIGIN=https://staging.tigerex.com

# External APIs
BINANCE_API_KEY=${BINANCE_API_KEY}
BINANCE_SECRET_KEY=${BINANCE_SECRET_KEY}

# Logging
LOG_FILE_ENABLED=true
LOG_FILE_PATH=/var/log/tigerex/app.log

# Monitoring
SENTRY_ENVIRONMENT=staging
SENTRY_TRACES_SAMPLE_RATE=0.2

# Feature Flags
FEATURE_FUTURES_TRADING=true
FEATURE_OPTIONS_TRADING=true