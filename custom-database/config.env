# TigerEx Database Configuration
# PostgreSQL + Redis Setup

# Database Service
DATABASE_URL=postgresql://tigerex:tigerex123@localhost:5432/tigerex_db

# Redis Cache
REDIS_URL=redis://localhost:6379

# Connection Pool
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# MongoDB (optional for document storage)
MONGODB_URL=mongodb://localhost:27017/tigerex

# Database Tables/Collections

# Users Table
USERS_TABLE=users
# Columns: user_id, email, password_hash, kyc_level, created_at, status

# Accounts Table
ACCOUNTS_TABLE=accounts
# Columns: account_id, user_id, account_type, balance, frozen_balance

# Orders Table
ORDERS_TABLE=orders
# Columns: order_id, user_id, pair, side, order_type, price, quantity, filled, status, created_at

# Transactions Table
TRANSACTIONS_TABLE=transactions
# Columns: tx_id, order_id, user_id, type, amount, status, hash, timestamp

# Deposits Table
DEPOSITS_TABLE=deposits
# Columns: deposit_id, user_id, asset, amount, tx_hash, status, timestamp

# Withdrawals Table
WITHDRAWALS_TABLE=withdrawals
# Columns: withdrawal_id, user_id, asset, amount, address, status, timestamp

# Blocks Table (for custom blockchain)
BLOCKS_TABLE=blocks
# Columns: number, hash, parent_hash, validator, timestamp, transactions, gas_used

# Accounts Table (blockchain)
BLOCK_ACCOUNTS_TABLE=block_accounts
# Columns: address, balance, nonce, code_hash, storage_root

# Tokens Table
TOKENS_TABLE=tokens
# Columns: chain, address, symbol, name, decimals, total_supply, creator

# Liquidity Pools Table
POOLS_TABLE=liquidity_pools
# Columns: pool_id, token_a, token_b, dex, liquidity_a, liquidity_b, shares

# Redis Keys
REDIS_WALLET_PREFIX=wallet:
REDIS_ORDER_BOOK_PREFIX=orderbook:
REDIS_PRICE_PREFIX=price:
REDIS_GAS_PREFIX=gas:

# Cache TTL (seconds)
CACHE_SHORT=30
CACHE_MEDIUM=300
CACHE_LONG=3600