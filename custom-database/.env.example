# TigerEx Environment Variables Template
# Copy this to .env and fill in your values

# ==================== DATABASE ====================

# PostgreSQL - REQUIRED
DB_HOST=localhost
DB_PORT=5432
DB_USER=tigerex
DB_PASSWORD=  # Set this!
DB_NAME=tigerex_db

# Connection pool
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ==================== REDIS ====================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=  # Optional
REDIS_DB=0

# ==================== MONGODB ====================

MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=  # Optional
MONGO_PASSWORD=  # Optional
MONGO_DB=tigerex

# ==================== CACHE TTL ====================

CACHE_SHORT=30
CACHE_MEDIUM=300
CACHE_LONG=3600

# ==================== BACKUP ====================

# Enable automated backups
BACKUP_ENABLED=true

# Backup schedule (cron)
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM

# S3 bucket for backups
BACKUP_S3_BUCKET=  # Set this!

# Retention days
BACKUP_RETENTION_DAYS=30# TigerEx Wallet API
# create_wallet() - 24-word seed
